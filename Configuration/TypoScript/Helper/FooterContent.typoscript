lib.footerContent = COA
lib.footerContent {
    10 = CONTENT
    10 {
        table = tt_content
        select {
            # The page with ID = 123 is the source.
            pidInList = {site:settings.plugin.genf.vorgaben.footerContentId}
            pidInList.insertData = 1
            # Sorting is the same as in the backend.
            orderBy = sorting
            # Select the content of all column.
            where = {#colPos} = 100
        }
    }
}