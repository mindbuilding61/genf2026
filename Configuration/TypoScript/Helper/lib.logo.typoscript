# Fallback only – Mainmenu.html uses site settings via Fluid ViewHelper.
lib.logo = TEXT
lib.logo {
    insertData = 1
    value = <img src="{site:settings.plugin.genf.sitelogo.sitelogo}" alt="{site:settings.plugin.genf.sitelogo.siteTitle}" class="ps-logo" width="{site:settings.plugin.genf.sitelogo.siteLogoWidth}" />
    stdWrap.htmlSpecialChars = 0
}
